# Copy to .env and adjust. Loaded via python-dotenv (from the audio's folder and cwd).
# Summarization uses a headless agent CLI — auth is the CLI's own (its login), no key here.

# faster-whisper model: tiny, base, small, medium, large-v3
WHISPER_MODEL=large-v3
# Audio language (ISO code; empty = auto-detect)
WHISPER_LANG=pt
# Transcription device: auto (GPU, fall back to CPU) | cuda (force GPU) | cpu (force CPU).
# GPU needs the 'gpu' extra: uv sync --extra transcribe --extra gpu
WHISPER_DEVICE=auto
# Whisper beam size (1 = ~2x faster, slightly less accurate; default 5).
WHISPER_BEAM_SIZE=5
# Batched-inference batch size (bigger = faster on GPU, more VRAM; default 8).
WHISPER_BATCH_SIZE=8

# --- Summarization provider ---------------------------------------------------
# Which agent CLI generates the summary. One of: claude-cli | opencode | codex-cli
SUMMARY_PROVIDER=claude-cli
# Model for the summary.
#  - claude-cli: sonnet | opus | haiku (default: sonnet)
#  - codex-cli:  e.g. gpt-5.5 (default: gpt-5.5)
#  - opencode:   REQUIRED and MUST be "provider/model",
#                e.g. anthropic/claude-sonnet-4-5, openai/gpt-5.5
SUMMARY_MODEL=
